# ─── Database ───────────────────────────────────────────────
# Async URL for app (uses fleetpulse_app role, subject to RLS)
DATABASE_URL=postgresql+asyncpg://fleetpulse_app:fleetpulse_app_dev@localhost:5432/fleetpulse
# Sync URL for Alembic migrations (uses owner role, bypasses RLS)
DATABASE_URL_SYNC=postgresql+psycopg2://fleetpulse:fleetpulse_dev@localhost:5432/fleetpulse

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-random-256-bit-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ─── Claude AI (Phase 7) ───────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-5-20250929

# ─── File Storage (Phase 2+) ───────────────────────────────
# S3_ENDPOINT=https://s3.me-south-1.amazonaws.com
# S3_BUCKET=fleetpulse-uploads
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=me-south-1

# ─── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Debug ──────────────────────────────────────────────────
DEBUG=true
