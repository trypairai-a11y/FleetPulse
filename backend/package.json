{
  "name": "darb-backend",
  "version": "1.0.0",
  "description": "Darb - Delivery Fleet Management System Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "worker:notifications": "tsx src/queues/notificationWorker.ts",
    "worker:notifications:prod": "node dist/queues/notificationWorker.js",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:agent": "jest --testPathPatterns=agent",
    "test:lint-rules": "node --test eslint-rules/__tests__/",
    "lint": "eslint src/ --ext .ts",
    "lint:tenant": "eslint src/agent/ src/__tests__/agent/ src/routes/aiChiefOfStaff.ts src/routes/ai.ts --ext .ts --no-eslintrc --resolve-plugins-relative-to . --rulesdir eslint-rules --parser @typescript-eslint/parser --parser-options=ecmaVersion:2022,sourceType:module --rule \"{\\\"no-prisma-without-tenant\\\":\\\"error\\\"}\" --no-error-on-unmatched-pattern",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:seed:prod": "vercel env pull .env.production.local --environment=production --yes && env $(grep -v '^#' .env.production.local | xargs) tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "postinstall": "prisma generate && (prisma migrate deploy || echo 'migrate deploy skipped')"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@prisma/client": "^5.22.0",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.48.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.73.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.1",
    "express-rate-limit": "^8.3.2",
    "imapflow": "^1.3.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^5.22.0",
    "rate-limit-redis": "^4.3.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.13.1",
    "uuid": "^10.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-local-rules": "^3.0.2",
    "jest": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
