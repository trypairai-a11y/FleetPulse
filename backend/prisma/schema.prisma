  USER
}

enum LeaveType {
  SICK
  VACATION
  EMERGENCY
  PERSONAL
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TalabatSessionStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ViolationEventType {
  SELFIE_FAIL
  GPS_OFF
  EQUIPMENT_MISSING
  SHIFT_NOT_BOOKED
  ORDER_CLICK_THROUGH
  LATE_CLOCK_IN
  EARLY_CLOCK_OUT
  ZONE_MISMATCH
  OUT_OF_ZONE
  CASH_THRESHOLD_EXCEEDED
}

enum ViolationType {
  LATE_PICKUP
  ORDER_REJECTION_TIMEOUT
  DROP_OFF_IN_ADVANCE
  ORDER_SLIGHTLY_LATE
  ORDER_VERY_LATE
  INVALID_DELIVERY_PHOTO
  GPS_NOT_UPLOADING
  CASH_DISCREPANCY
  DELIVEROO_UNASSIGNED_ORDER
  AMERICANA_LATE_ARRIVAL
  AMERICANA_NO_SHOW
  AMERICANA_EARLY_DEPARTURE_QUIT
}

enum ViolationStatus {
  ESTABLISHED
  UNDER_REVIEW
  OVERTURNED
  EXPIRED
}

enum AppealStatus {
  NOT_RAISED
  PENDING
  APPROVED
  REJECTED
}

enum CashTransactionType {
  COLLECTION
  CASH_OUT
  INVOICE_DEDUCTION
}

enum KpiCategory {
  ATTENDANCE
  ORDERS
  DELIVERY_EFFICIENCY
  FINANCIAL
  VIOLATION
  CUSTOM
}

enum KpiUnit {
  PERCENTAGE
  COUNT
  MINUTES
  HOURS
  CURRENCY
  SCORE
}

// ─── Models ─────────────────────────────────────────────

// 1. Tenant
model Tenant {
  id               String           @id @default(uuid())
  name             String
  subscriptionPlan SubscriptionPlan @default(FREE)
  // Phase 2 Wave 1 — additive design-partner / billing fields. Wave 5 runs the
  // migration. designPartner=true unlocks the per-tenant override; trialEndsAt
  // is the 14-day onboarding grace cutoff (NULL = not on trial).
  designPartner     Boolean         @default(false)
  monthlyOverrideKd Decimal?        @db.Decimal(10, 3)
  trialEndsAt       DateTime?
  settings         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  companies                 Company[]
  users                     User[]
  drivers                   Driver[]
  shifts                    Shift[]
  attendanceRecords         AttendanceRecord[]
  orderLogs                 OrderLog[]
  cashRecords               CashRecord[]
  cashTransactions          CashTransaction[]
  pendingDuesLedgers        PendingDuesLedger[]
  vehicleInspections        VehicleInspection[]
  maintenanceRecords        MaintenanceRecord[]
  aiScores                  AiScore[]
  alerts                    Alert[]
  aiDigests                 AiDigest[]
  auditLogs                 AuditLog[]
  tickets                   Ticket[]
  leaveRequests             LeaveRequest[]
  recruitmentPipeline       RecruitmentPipeline[]
  vehicles                  Vehicle[]
  talabatSessions           TalabatSession[]
  talabatViolationEvents    TalabatViolationEvent[]
  talabatDailyMetrics       TalabatDailyMetrics[]
  deliverooDailyMetrics     DeliverooDailyMetrics[]
  keetaDailyMetrics         KeetaDailyMetrics[]
  americanaDailyOrders      AmericanaDailyOrders[]
  kpiDefinitions            KpiDefinition[]
  kpiRecords                KpiRecord[]
  platformSettings          PlatformSettings[]
  platformInventory         PlatformInventory[]
  notifications             Notification[]
  notificationRules         NotificationRule[]
  notificationDeliveries    NotificationDelivery[]
  driverRestrictions        DriverRestriction[]
  courierOnlineSessions     CourierOnlineSession[]
  violations                Violation[]
  penalties                 Penalty[]
  appeals                   Appeal[]
  orderEvents               OrderEvent[]
  aiInsights                AiInsight[]
  demandHeatmaps            DemandHeatmap[]
  courierAttendanceSlots    CourierAttendanceSlot[]
  shiftComplianceConfig     ShiftComplianceConfig?
  keetaAvailableSlots       KeetaAvailableShiftSlot[]
  deliveryAreas             DeliveryArea[]
  partners                  Partner[]
  incentiveTargetRounds     IncentiveTargetRound[]
  courierIncentivePayouts   CourierIncentivePayout[]
  billings                  Billing[]
  taxInvoices               TaxInvoice[]
  paymentWithdrawals        PaymentWithdrawal[]
  agentRunLogs              AgentRunLog[]
  pendingAgentActions       PendingAgentAction[]
  agentActions              AgentAction[]
  agentMemories             AgentMemory[]
  pinnedViews               PinnedView[]
  performanceSnapshots      PerformanceSnapshot[]
  metricEvents              MetricEvent[]
  ingestRuns                IngestRun[]
  americanaChains           AmericanaChain[]
  americanaStores           AmericanaStore[]
  americanaContracts        AmericanaContract[]
  americanaChainRates       AmericanaChainRate[]
  americanaStoreAssignments AmericanaStoreAssignment[]
  americanaDailyIngestions  AmericanaDailyIngestion[]
  sims                      Sim[]
}

// 2. Company
model Company {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  platform     Platform
  licenseCount Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant              Tenant                @relation(fields: [tenantId], references: [id])
  drivers             Driver[]
  vehicles            Vehicle[]
  recruitmentPipeline RecruitmentPipeline[]
  tickets             Ticket[]

  @@index([tenantId])
}

// 3. User
model User {
  id           String    @id @default(uuid())
  tenantId     String
  email        String    @unique
  phone        String?
  passwordHash String
  name         String
  role         UserRole  @default(VIEWER)
  // Phase 2 Wave 1 — super-admin flag. Read on every request from the DB
  // (NOT from JWT) by the requireSuperAdmin middleware to prevent stale-flag
  // attacks (T-02-06).
  isSuperAdmin Boolean   @default(false)
  jobGrade     String? // e.g. "Team Leader", "Supervisor", "Senior Supervisor", "Area Manager"
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant                Tenant               @relation(fields: [tenantId], references: [id])
  supervisedDrivers     Driver[]             @relation("DriverSupervisor")
  issuedCommands        DeviceCommand[]      @relation("CommandIssuer")
  acknowledgedAlerts    Alert[]              @relation("AlertAcknowledger")
  reviewedLeaves        LeaveRequest[]       @relation("LeaveReviewer")
  assignedTickets       Ticket[]             @relation("TicketAssignee")
  submittedTickets      Ticket[]             @relation("TicketSubmitterUser")
  notifications         Notification[]
  createdAmericanaRates AmericanaChainRate[] @relation("AmericanaChainRateCreator")
  approvedAgentActions  AgentAction[]        @relation("AgentActionApprover")
  pinnedViews           PinnedView[]         @relation("PinnedViewOwner")
  metricEvents          MetricEvent[]        @relation("MetricEventActor")

  @@index([tenantId])
}

// 4. Driver
model Driver {
  id                 String       @id @default(uuid())
  tenantId           String
  companyId          String
  name               String
  phone              String
  platform           Platform
  platformDriverId   String?
  utr                String?
  vehicleType        VehicleType
  zone               String?
  batchNumber        String?
  status             DriverStatus @default(ACTIVE)
  hireDate           DateTime
  photoUrl           String?
  supervisorId       String?
  monthlySalary      Float?
  monthlyOffDaysUsed Int          @default(0)
  offDaysResetMonth  String? // format: "YYYY-MM", reset tracker
  performanceTier    String? // GOLD | SILVER | BRONZE | WATCHLIST (R9)
  tierComputedAt     DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  // Document expiry dates and statuses
  healthCertExpiry       DateTime?
  healthCertStatus       String? // VALID, EXPIRING, EXPIRED, MISSING
  workPermitExpiry       DateTime?
  workPermitStatus       String?
  foodHandlingCertExpiry DateTime?
  foodHandlingCertStatus String?
  vehicleRegExpiry       DateTime?
  vehicleRegStatus       String?
  vehicleInsuranceExpiry DateTime?
  vehicleInsuranceStatus String?
  drivingLicenseExpiry   DateTime?
  drivingLicenseStatus   String?
  civilIdExpiry          DateTime?
  civilIdStatus          String?

  tenant     Tenant  @relation(fields: [tenantId], references: [id])
  company    Company @relation(fields: [companyId], references: [id])
  supervisor User?   @relation("DriverSupervisor", fields: [supervisorId], references: [id])

  inventory                 DriverInventory[]
  shifts                    Shift[]
  attendanceRecords         AttendanceRecord[]
  orderLogs                 OrderLog[]
  cashRecords               CashRecord[]
  cashTransactions          CashTransaction[]
  pendingDuesLedgers        PendingDuesLedger[]
  vehicleInspections        VehicleInspection[]
  maintenanceRecords        MaintenanceRecord[]
  aiScores                  AiScore[]
  alerts                    Alert[]
  capturedOrders            CapturedOrder[]
  locationLogs              LocationLog[]
  appUsageLogs              AppUsageLog[]
  device                    Device?
  assignedVehicle           Vehicle?                   @relation("AssignedDriver")
  leaveRequests             LeaveRequest[]
  restrictions              DriverRestriction[]
  tickets                   Ticket[]                   @relation("TicketDriver")
  submittedTickets          Ticket[]                   @relation("TicketSubmitterDriver")
  talabatSessions           TalabatSession[]
  talabatViolationEvents    TalabatViolationEvent[]
  talabatDailyMetrics       TalabatDailyMetrics[]
  deliverooDailyMetrics     DeliverooDailyMetrics[]
  keetaDailyMetrics         KeetaDailyMetrics[]
  americanaDailyOrders      AmericanaDailyOrders[]
  talabatDeliveries         TalabatDelivery[]
  kpiRecords                KpiRecord[]
  courierOnlineSessions     CourierOnlineSession[]
  violations                Violation[]
  penalties                 Penalty[]
  aiInsights                AiInsight[]
  courierAttendanceSlots    CourierAttendanceSlot[]
  courierIncentivePayouts   CourierIncentivePayout[]
  americanaStoreAssignments AmericanaStoreAssignment[]
  sims                      Sim[]
  performanceSnapshots      PerformanceSnapshot[]

  @@index([tenantId])
  @@index([companyId])
  @@index([platform])
  @@index([tenantId, platform, status])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([phone(ops: raw("gin_trgm_ops"))], type: Gin)
}

// 5. DriverRestriction
model DriverRestriction {
  id          String          @id @default(uuid())
  tenantId    String
  driverId    String
  type        RestrictionType
  startDate   DateTime
  endDate     DateTime? // null = permanent
  reason      String?
  processedAt DateTime? // when attendance records were auto-generated
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@index([tenantId])
  @@index([driverId])
  @@index([startDate])
}

// 6. DriverInventory
model DriverInventory {
  id           String            @id @default(uuid())
  driverId     String
  itemType     InventoryItemType
  issued       Boolean           @default(false)
  quantity     Int               @default(0)
  issuedDate   DateTime?
  returnedDate DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  driver Driver @relation(fields: [driverId], references: [id])

  @@index([driverId])
}

// 6. RecruitmentPipeline
model RecruitmentPipeline {
  id                String           @id @default(uuid())
  tenantId          String
  candidateName     String
  phone             String
  stage             RecruitmentStage @default(AGENCY_REFERRAL)
  agency            String?
  expectedDate      DateTime?
  notes             String?
  assignedCompanyId String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  assignedCompany Company? @relation(fields: [assignedCompanyId], references: [id])

  @@index([tenantId])
}

// 7. Vehicle
model Vehicle {
  id                 String        @id @default(uuid())
  tenantId           String
  companyId          String
  plateNumber        String        @unique
  vehicleType        VehicleType
  make               String
  model              String
  year               Int
  color              String?
  chassisNumber      String?
  mileage            Int           @default(0)
  fuelType           String        @default("Petrol")
  ownerCompany       String?
  driverIqama        String?
  status             VehicleStatus @default(ACTIVE)
  assignedDriverId   String?       @unique
  insuranceExpiry    DateTime
  registrationExpiry DateTime
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  tenant         Tenant  @relation(fields: [tenantId], references: [id])
  company        Company @relation(fields: [companyId], references: [id])
  assignedDriver Driver? @relation("AssignedDriver", fields: [assignedDriverId], references: [id])

  inspections        VehicleInspection[]
  maintenanceRecords MaintenanceRecord[] @relation("VehicleMaintenance")
  spareMaintenance   MaintenanceRecord[] @relation("SpareVehicle")
  alerts             Alert[]
  tickets            Ticket[]

  @@index([tenantId])
  @@index([companyId])
}

// 8. Shift
model Shift {
  id                  String      @id @default(uuid())
  tenantId            String
  driverId            String
  date                DateTime
  platform            Platform
  zone                String?
  scheduledStart      DateTime
  scheduledEnd        DateTime
  actualStart         DateTime? // Darb app clock-in (selfie-gated)
  actualEnd           DateTime? // Darb app clock-out
  platformClockIn     DateTime? // Synced from delivery platform (Keeta online session, Talabat XLSX, etc.)
  platformClockOut    DateTime?
  varianceMinutes     Int? // |actualStart - platformClockIn| — diagnostic
  status              ShiftStatus @default(BOOKED)
  isValid             Boolean?
  plannedHoursMinutes Int?
  actualHoursMinutes  Int?
  selfieUrl           String?
  selfieLocation      Json?
  clockInMethod       String?
  clockOutMethod      String?
  shiftScreenshotUrl  String?
  deliveryArea        String? // Amendment B: Hawally, Avenues, Salmiya, etc.
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  driver            Driver             @relation(fields: [driverId], references: [id])
  attendanceRecords AttendanceRecord[]
  orderLogs         OrderLog[]
  talabatSessions   TalabatSession[]

  @@index([tenantId])
  @@index([driverId])
  @@index([date])
  @@index([tenantId, date])
  @@index([tenantId, driverId, date])
  @@index([tenantId, deliveryArea, date])
}

// 9. AttendanceRecord
model AttendanceRecord {
  id               String           @id @default(uuid())
  tenantId         String
  driverId         String
  shiftId          String?
  date             DateTime
  status           AttendanceStatus
  lateMinutes      Int              @default(0)
  source           String           @default("manual")
  // Dual clock tracking — Darb app vs delivery platform
  darbClockIn      DateTime?
  darbClockOut     DateTime?
  platformClockIn  DateTime?
  platformClockOut DateTime?
  varianceMinutes  Int? // |darbClockIn - platformClockIn|
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])
  shift  Shift? @relation(fields: [shiftId], references: [id])

  @@unique([tenantId, driverId, date], name: "tenantId_driverId_date")
  @@index([tenantId])
  @@index([driverId])
  @@index([date])
}

// 10. OrderLog
model OrderLog {
  id             String      @id @default(uuid())
  tenantId       String
  driverId       String
  shiftId        String?
  date           DateTime
  platform       Platform
  orderCount     Int
  distanceKm     Decimal?    @db.Decimal(10, 3)
  cashCollected  Decimal?    @db.Decimal(10, 3)
  tips           Decimal?    @db.Decimal(10, 3)
  totalAmount    Decimal?    @db.Decimal(10, 3)
  orderNumber    String?
  paymentSource  String?
  restaurantName String?
  arrivalTime    DateTime?
  screenshotUrl  String?
  source         OrderSource @default(MANUAL)
  rawData        Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])
  shift  Shift? @relation(fields: [shiftId], references: [id])

  @@index([tenantId])
  @@index([driverId])
  @@index([date])
  @@index([tenantId, date])
  @@index([tenantId, platform, date])
}

// 11. CashRecord
model CashRecord {
  id                String         @id @default(uuid())
  tenantId          String
  driverId          String
  date              DateTime
  salesAmount       Decimal        @db.Decimal(10, 3)
  collectionAmount  Decimal        @default(0) @db.Decimal(10, 3)
  depositMethod     DepositMethod?
  depositReceiptUrl String?
  pendingDues       Decimal        @db.Decimal(10, 3)
  status            CashStatus     @default(PENDING)
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@index([tenantId])
  @@index([driverId])
  @@index([date])
  @@index([tenantId, status, date])
  @@index([tenantId, driverId, date])
}

// 11b. CashTransaction
model CashTransaction {
  id             String              @id @default(uuid())
  tenantId       String
  driverId       String
  date           DateTime
  type           CashTransactionType
  amount         Decimal             @db.Decimal(10, 3)
  orderNumber    String?
  description    String?
  runningBalance Decimal             @db.Decimal(10, 3)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@index([tenantId])
  @@index([driverId])
  @@index([date])
}

// 12. PendingDuesLedger
model PendingDuesLedger {
  id               String       @id @default(uuid())
  tenantId         String
  driverId         String
  month            DateTime
  openingBalance   Decimal      @db.Decimal(10, 3)
  totalSales       Decimal      @db.Decimal(10, 3)
  totalCollection  Decimal      @db.Decimal(10, 3)
  cashDeposits     Decimal      @db.Decimal(10, 3)
  bankTransfers    Decimal      @db.Decimal(10, 3)
  incentives       Decimal      @db.Decimal(10, 3)
  adjustments      Decimal      @db.Decimal(10, 3)
  closingBalance   Decimal      @db.Decimal(10, 3)
  dailySales       Json
  dailyCollections Json
  status           LedgerStatus @default(OPEN)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@unique([tenantId, driverId, month], name: "tenantId_driverId_month")
  @@index([tenantId])
  @@index([driverId])
  @@index([month])
}

// 13. VehicleInspection
model VehicleInspection {
  id               String           @id @default(uuid())
  tenantId         String
  vehicleId        String
  driverId         String
  date             DateTime
  status           InspectionStatus
  photos           Json?
  notes            String?
  deductionApplied Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  driver  Driver  @relation(fields: [driverId], references: [id])

  @@index([tenantId])
  @@index([vehicleId])
}

// 14. MaintenanceRecord
model MaintenanceRecord {
  id             String              @id @default(uuid())
  tenantId       String
  vehicleId      String
  driverId       String?
  category       MaintenanceCategory
  type           String
  cost           Decimal             @db.Decimal(10, 3)
  vendor         String?
  receiptUrl     String?
  spareVehicleId String?
  status         MaintenanceStatus   @default(REQUESTED)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  vehicle      Vehicle  @relation("VehicleMaintenance", fields: [vehicleId], references: [id])
  driver       Driver?  @relation(fields: [driverId], references: [id])
  spareVehicle Vehicle? @relation("SpareVehicle", fields: [spareVehicleId], references: [id])

  @@index([tenantId])
  @@index([vehicleId])
}

// 15. Device
model Device {
  id            String       @id @default(uuid())
  tenantId      String
  driverId      String?      @unique
  imei          String       @unique
  model         String
  osVersion     String
  agentVersion  String?
  lastSeen      DateTime?
  batteryLevel  Int?
  isOnline      Boolean      @default(false)
  status        DeviceStatus @default(ACTIVE)
  lastLatitude  Decimal?     @db.Decimal(10, 7)
  lastLongitude Decimal?     @db.Decimal(10, 7)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  driver         Driver?         @relation(fields: [driverId], references: [id])
  capturedOrders CapturedOrder[]
  locationLogs   LocationLog[]
  appUsageLogs   AppUsageLog[]
  commands       DeviceCommand[]
  sims           Sim[]

  @@index([driverId])
}

model Sim {
  id          String    @id @default(uuid())
  tenantId    String
  phoneNumber String
  carrier     String?
  status      SimStatus @default(ACTIVE)
  driverId    String?
  deviceId    String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  driver Driver? @relation(fields: [driverId], references: [id])
  device Device? @relation(fields: [deviceId], references: [id])

  @@unique([tenantId, phoneNumber])
  @@index([tenantId, status])
  @@index([driverId])
  @@index([deviceId])
}

// 16. CapturedOrder
model CapturedOrder {
  id               String   @id @default(uuid())
  deviceId         String
  driverId         String
  platform         Platform
  notificationText String
  parsedData       Json?
  capturedAt       DateTime

  device Device @relation(fields: [deviceId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@index([deviceId])
  @@index([driverId])
}

// 17. LocationLog
model LocationLog {
  id         String   @id @default(uuid())
  deviceId   String
  driverId   String
  latitude   Decimal  @db.Decimal(10, 7)
  longitude  Decimal  @db.Decimal(10, 7)
  accuracy   Decimal  @db.Decimal(10, 2)
  speed      Decimal? @db.Decimal(10, 2)
  capturedAt DateTime

  device Device @relation(fields: [deviceId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@index([driverId, capturedAt])
  @@index([deviceId])
}

// 18. AppUsageLog
model AppUsageLog {
  id              String   @id @default(uuid())
  deviceId        String
  driverId        String
  appPackage      String
  eventType       String
  durationSeconds Int?
  capturedAt      DateTime

  device Device @relation(fields: [deviceId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@index([deviceId])
  @@index([driverId])
}

// 19. DeviceCommand
model DeviceCommand {
  id             String            @id @default(uuid())
  deviceId       String
  command        DeviceCommandType
  payload        Json?
  status         CommandStatus     @default(PENDING)
  issuedById     String
  issuedAt       DateTime          @default(now())
  acknowledgedAt DateTime?

  device   Device @relation(fields: [deviceId], references: [id])
  issuedBy User   @relation("CommandIssuer", fields: [issuedById], references: [id])

  @@index([deviceId])
}

// 20. AiScore
model AiScore {
  id              String     @id @default(uuid())
  tenantId        String
  driverId        String
  date            DateTime
  compositeScore  Int
  attendanceScore Int
  deliveryScore   Int
  financialScore  Int
  equipmentScore  Int
  platformScore   Int
  breakdown       Json?
  trend           ScoreTrend @default(STABLE)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@unique([tenantId, driverId, date], name: "tenantId_driverId_date_score")
  @@index([tenantId])
  @@index([driverId])
  @@index([date])
  @@index([tenantId, date])
}

// 21. Alert
model Alert {
  id               String        @id @default(uuid())
  tenantId         String
  type             String
  severity         AlertSeverity
  title            String
  message          String
  driverId         String?
  vehicleId        String?
  data             Json?
  status           AlertStatus   @default(ACTIVE)
  acknowledgedById String?
  acknowledgedAt   DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  driver         Driver?  @relation(fields: [driverId], references: [id])
  vehicle        Vehicle? @relation(fields: [vehicleId], references: [id])
  acknowledgedBy User?    @relation("AlertAcknowledger", fields: [acknowledgedById], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, driverId, type, createdAt])
}

// 22. AiDigest
model AiDigest {
  id          String   @id @default(uuid())
  tenantId    String
  date        DateTime
  content     Json
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, date])
  @@index([tenantId])
}

// 23. AuditLog
model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  action     String
  entityType String
  entityId   String?
  changes    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([entityType, entityId])
}

// 24. Ticket
model Ticket {
  id                String         @id @default(uuid())
  tenantId          String
  ticketNumber      String         @unique
  category          TicketCategory
  priority          TicketPriority @default(MEDIUM)
  title             String
  description       String
  submitterType     SubmitterType
  submitterDriverId String?
  submitterUserId   String?
  assignedToId      String?
  status            TicketStatus   @default(OPEN)
  photos            Json?
  resolution        String?
  resolvedAt        DateTime?
  slaDeadline       DateTime?
  platform          Platform?
  companyId         String?
  driverId          String?
  vehicleId         String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  submitterDriver Driver?  @relation("TicketSubmitterDriver", fields: [submitterDriverId], references: [id])
  submitterUser   User?    @relation("TicketSubmitterUser", fields: [submitterUserId], references: [id])
  assignedTo      User?    @relation("TicketAssignee", fields: [assignedToId], references: [id])
  company         Company? @relation(fields: [companyId], references: [id])
  driver          Driver?  @relation("TicketDriver", fields: [driverId], references: [id])
  vehicle         Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([priority])
}

// 25. LeaveRequest
model LeaveRequest {
  id           String      @id @default(uuid())
  tenantId     String
  driverId     String
  type         LeaveType
  startDate    DateTime
  endDate      DateTime
  reason       String?
  status       LeaveStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  reviewNotes  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  driver     Driver @relation(fields: [driverId], references: [id])
  reviewedBy User?  @relation("LeaveReviewer", fields: [reviewedById], references: [id])

  @@index([tenantId])
  @@index([driverId])
}

// 26. TalabatSession
model TalabatSession {
  id                String               @id @default(uuid())
  tenantId          String
  driverId          String
  shiftId           String?
  date              DateTime
  zone              String
  vehicleType       VehicleType
  sessionCode       String
  plannedStart      DateTime
  plannedEnd        DateTime
  approvedStart     DateTime?
  approvedEnd       DateTime?
  actualStart       DateTime?
  actualEnd         DateTime?
  plannedHours      Decimal              @db.Decimal(5, 2)
  approvedHours     Decimal?             @db.Decimal(5, 2)
  actualHours       Decimal?             @db.Decimal(5, 2)
  deliveries        Int                  @default(0)
  cashCollected     Decimal              @default(0) @db.Decimal(10, 3)
  tips              Decimal              @default(0) @db.Decimal(10, 3)
  distanceKm        Decimal?             @db.Decimal(10, 3)
  status            TalabatSessionStatus @default(PLANNED)
  faceVerified      Boolean              @default(false)
  equipmentVerified Boolean              @default(false)
  gpsViolation      Int?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  tenant          Tenant                  @relation(fields: [tenantId], references: [id])
  driver          Driver                  @relation(fields: [driverId], references: [id])
  shift           Shift?                  @relation(fields: [shiftId], references: [id])
  violationEvents TalabatViolationEvent[]
  deliveryItems   TalabatDelivery[]

  @@index([tenantId])
  @@index([driverId])
  @@index([date])
  @@index([zone, date])
  @@index([tenantId, date])
  @@index([tenantId, driverId, date])
  @@index([tenantId, status, date])
}

// 27. TalabatViolationEvent
model TalabatViolationEvent {
  id          String             @id @default(uuid())
  tenantId    String
  driverId    String
  sessionId   String?
  type        ViolationEventType
  description String
  metadata    Json?
  resolved    Boolean            @default(false)
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime           @default(now())

  tenant  Tenant          @relation(fields: [tenantId], references: [id])
  driver  Driver          @relation(fields: [driverId], references: [id])
  session TalabatSession? @relation(fields: [sessionId], references: [id])

  @@index([tenantId])
  @@index([driverId])
  @@index([type])
  @@index([createdAt])
  @@index([tenantId, driverId, type, createdAt])
}

// 28. TalabatDelivery - individual delivery items within a session
model TalabatDelivery {
  id              String    @id @default(uuid())
  tenantId        String
  driverId        String
  sessionId       String
  date            DateTime
  platformOrderId String
  shortCode       String
  finishedAt      DateTime?
  orderType       String    @default("food")
  amount          Decimal   @default(0) @db.Decimal(10, 3)
  tip             Decimal   @default(0) @db.Decimal(10, 3)
  distanceKm      Decimal?  @db.Decimal(10, 3)
  status          String    @default("COMPLETED")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  driver  Driver         @relation(fields: [driverId], references: [id])
  session TalabatSession @relation(fields: [sessionId], references: [id])

  @@index([tenantId])
  @@index([driverId])
  @@index([sessionId])
  @@index([date])
}

// 29. KeetaDailyMetrics - mirrors the 27-column Keeta dashboard export
model KeetaDailyMetrics {
  id                   String   @id @default(uuid())
  tenantId             String
  driverId             String
  date                 DateTime
  courierPlatformId    String?
  supervisorName       String?
  vehicleType          String?
  onShift              Boolean  @default(false)
  validDay             Boolean  @default(false)
  onlineTime           Int      @default(0) // minutes
  validOnlineTime      Int      @default(0) // minutes
  peakOnlineMinutes    Int      @default(0)
  acceptedTasks        Int      @default(0)
  restaurantArrivals   Int      @default(0)
  deliveredTasks       Int      @default(0)
  largeOrdersCompleted Int      @default(0)
  cancelledTasks       Int      @default(0)
  rejectedTasks        Int      @default(0)
  rejectedByCourier    Int      @default(0)
  rejectedAuto         Int      @default(0)
  cancellationRate     Decimal? @db.Decimal(5, 4)
  completionRate       Decimal? @db.Decimal(5, 4)
  onTimeRate           Decimal? @db.Decimal(5, 4)
  largeOrderOnTimeRate Decimal? @db.Decimal(5, 4)
  avgDeliveryMinutes   Decimal? @db.Decimal(6, 2)
  over55minProportion  Decimal? @db.Decimal(5, 4)
  overdueOrders        Int      @default(0)
  severelyOverdue      Int      @default(0)
  source               String   @default("MANUAL")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@unique([tenantId, driverId, date])
  @@index([tenantId])
  @@index([driverId])
  @@index([date])
}

// 29.2. IngestRun - audit trail for scheduled ingestion (Keeta portal scraper, OCR batches, etc.)
model IngestRun {
  id         String    @id @default(cuid())
  tenantId   String
  platform   Platform
  source     String // "PORTAL_SCRAPER" | "MANUAL_UPLOAD" | "OCR_MOBILE" | "OCR_WEB"
  status     String // "SUCCESS" | "PARTIAL" | "FAILED"
  startedAt  DateTime
  finishedAt DateTime?
  rowsIn     Int?
  rowsOk     Int?
  errorLog   String?
  tenant     Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId, platform, startedAt])
}

// 29.1.5 DeliverooDailyMetrics - per-driver Deliveroo rider "My deliveries" totals (OCR + manual)
model DeliverooDailyMetrics {
  id              String    @id @default(cuid())
  tenantId        String
  driverId        String
  shiftDate       DateTime
  codCollectedKwd Decimal   @db.Decimal(10, 3)
  tipsKwd         Decimal   @db.Decimal(10, 3)
  deliveriesCount Int
  unassignedCount Int       @default(0)
  hourlyBuckets   Json // int[9] mapped to 08,10,12,14,16,18,20,22,24
  source          String // "OCR_MOBILE" | "OCR_WEB" | "MANUAL_UPLOAD"
  status          String    @default("PARSED") // PARSED | PENDING_REVIEW | APPROVED | REJECTED
  rawImageUrl     String?
  ocrConfidence   Float?
  ocrRaw          Json?
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNote      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@unique([tenantId, driverId, shiftDate])
  @@index([tenantId, shiftDate])
  @@index([tenantId, status])
  @@index([driverId, shiftDate])
}

// 29.1. TalabatDailyMetrics - per-driver daily KPIs sourced from mobile OCR / manual upload / portal API
model TalabatDailyMetrics {
  id              String    @id @default(cuid())
  tenantId        String
  driverId        String
  shiftDate       DateTime
  utr             Float?
  ordersCompleted Int?
  onlineHours     Float?
  earnings        Float?
  source          String // "OCR_MOBILE" | "OCR_WEB" | "MANUAL_UPLOAD" | "PORTAL_API"
  status          String    @default("PARSED") // "PARSED" | "PENDING_REVIEW" | "APPROVED" | "REJECTED"
  rawImageUrl     String?
  ocrConfidence   Float?
  ocrRaw          Json?
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNote      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@unique([tenantId, driverId, shiftDate])
  @@index([tenantId, shiftDate])
  @@index([tenantId, status])
  @@index([driverId, shiftDate])
}

// 30. PlatformSettings - configurable targets, KPIs, and inventory per platform
model PlatformSettings {
  id                 String   @id @default(uuid())
  tenantId           String
  platform           Platform
  targets            Json // { mainTarget: {...}, subTargets: [...] }
  kpis               Json? // { weights: {...}, thresholds: {...}, gradingScale: [...] }
  shiftRules         Json? // { defaultHours: 12, maxLateMinutes: 1, ... }
  zones              Json? // ["Ardiya", "Hawally", ...]
  violationRules     Json? // penalty points, auto-detect toggles per violation type
  cashRules          Json? // deposit deadlines, overdue thresholds, collection policies
  bookingRules       Json? // shift booking windows, reminders, limits
  documentRules      Json? // required docs, expiry warning days
  notificationConfig Json? // notification preferences per event type
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, platform])
  @@index([tenantId])
}

// 31. PlatformInventory - total stock of equipment items per platform
model PlatformInventory {
  id        String            @id @default(uuid())
  tenantId  String
  platform  Platform
  itemType  InventoryItemType
  total     Int               @default(0)
  issued    Int               @default(0)
  available Int               @default(0)
  minStock  Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, platform, itemType])
  @@index([tenantId])
}

// 29. AmericanaDailyOrders - daily order counts per driver per store
model AmericanaDailyOrders {
  id          String   @id @default(uuid())
  tenantId    String
  driverId    String
  month       DateTime
  chain       String? // legacy free-text, kept 3 months then drop
  chainId     String?
  empId       String?
  storeName   String? // legacy free-text, kept 3 months then drop
  storeId     String?
  company     String?
  position    String? // Car or Bike
  dailyOrders Json // { "01": 19, "02": 20, ... "28": 30 }
  totalOrders Int      @default(0)
  source      String   @default("MANUAL")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  driver   Driver          @relation(fields: [driverId], references: [id])
  chainRef AmericanaChain? @relation(fields: [chainId], references: [id])
  storeRef AmericanaStore? @relation(fields: [storeId], references: [id])

  @@unique([tenantId, driverId, month])
  @@index([tenantId])
  @@index([driverId])
  @@index([month])
  @@index([tenantId, chainId, month])
  @@index([tenantId, storeId, month])
}

// ─── Americana B2B fleet models ─────────────────────────────

model AmericanaChain {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  slug      String
  logoUrl   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant                 @relation(fields: [tenantId], references: [id])
  stores      AmericanaStore[]
  rates       AmericanaChainRate[]
  dailyOrders AmericanaDailyOrders[]

  @@unique([tenantId, slug])
  @@index([tenantId, active])
}

model AmericanaStore {
  id                 String   @id @default(uuid())
  tenantId           String
  chainId            String
  name               String
  area               String?
  managerName        String?
  managerPhone       String?
  backupContactName  String?
  backupContactPhone String?
  notes              String?
  active             Boolean  @default(true)
  carDailyTarget     Int?
  bikeDailyTarget    Int?
  carMonthlyTarget   Int?
  bikeMonthlyTarget  Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant      Tenant                     @relation(fields: [tenantId], references: [id])
  chain       AmericanaChain             @relation(fields: [chainId], references: [id])
  assignments AmericanaStoreAssignment[]
  dailyOrders AmericanaDailyOrders[]

  @@unique([tenantId, name])
  @@index([tenantId, chainId])
  @@index([tenantId, active])
}

model AmericanaContract {
  id              String    @id @default(uuid())
  tenantId        String
  contractRef     String
  signedDate      DateTime
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  originalFileUrl String
  ocrStatus       String    @default("PENDING") // PENDING | PROCESSING | DONE | FAILED
  ocrExtractedAt  DateTime?
  ocrConfidence   Float?
  ocrDraftRates   Json?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant               @relation(fields: [tenantId], references: [id])
  rates  AmericanaChainRate[]

  @@unique([tenantId, contractRef])
  @@index([tenantId, effectiveFrom])
}

model AmericanaChainRate {
  id            String    @id @default(uuid())
  tenantId      String
  chainId       String
  vehicleType   String // CAR | BIKE
  ratePerOrder  Decimal   @db.Decimal(10, 3)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  contractId    String?
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  chain         AmericanaChain     @relation(fields: [chainId], references: [id])
  contract      AmericanaContract? @relation(fields: [contractId], references: [id])
  createdByUser User               @relation("AmericanaChainRateCreator", fields: [createdBy], references: [id])

  @@index([tenantId, chainId, vehicleType, effectiveFrom])
  @@index([createdBy])
}

model AmericanaStoreAssignment {
  id                   String    @id @default(uuid())
  tenantId             String
  driverId             String
  storeId              String
  month                DateTime // first-of-month
  startDate            DateTime
  endDate              DateTime?
  vehicleType          String // CAR | BIKE
  reasonForChange      String?
  previousAssignmentId String?
  createdBy            String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant Tenant         @relation(fields: [tenantId], references: [id])
  driver Driver         @relation(fields: [driverId], references: [id])
  store  AmericanaStore @relation(fields: [storeId], references: [id])

  @@unique([tenantId, driverId, month, startDate])
  @@index([tenantId, storeId, month])
  @@index([tenantId, driverId, month])
}

model AmericanaDailyIngestion {
  id             String    @id @default(uuid())
  tenantId       String
  source         String // EMAIL | MANUAL_UPLOAD
  emailMessageId String?
  rawFileUrl     String
  capturedAt     DateTime  @default(now())
  ingestDate     DateTime
  status         String    @default("PENDING_REVIEW") // PENDING_REVIEW | APPROVED | REJECTED | FAILED
  parsedRows     Json
  rowCount       Int
  errorLog       String?
  approvedBy     String?
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, emailMessageId])
  @@index([tenantId, ingestDate])
  @@index([tenantId, status])
}

// 30. KpiDefinition - configurable KPI definitions with targets per platform
model KpiDefinition {
  id          String      @id @default(uuid())
  tenantId    String
  name        String // e.g. "On-Time Attendance", "Daily Orders", "Delivery Efficiency"
  description String?
  category    KpiCategory
  unit        KpiUnit
  platform    Platform? // null = common across all platforms
  target      Decimal?    @db.Decimal(10, 3)
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant  Tenant      @relation(fields: [tenantId], references: [id])
  records KpiRecord[]

  @@unique([tenantId, name, platform])
  @@index([tenantId])
  @@index([platform])
}

// 31. KpiRecord - daily KPI values per driver
model KpiRecord {
  id              String   @id @default(uuid())
  tenantId        String
  driverId        String
  kpiDefinitionId String
  date            DateTime
  value           Decimal  @db.Decimal(10, 3)
  target          Decimal? @db.Decimal(10, 3)
  score           Decimal? @db.Decimal(5, 2) // percentage of target achieved
  source          String   @default("COMPUTED") // COMPUTED, MANUAL, IMPORT
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  driver        Driver        @relation(fields: [driverId], references: [id])
  kpiDefinition KpiDefinition @relation(fields: [kpiDefinitionId], references: [id])

  @@unique([tenantId, driverId, kpiDefinitionId, date])
  @@index([tenantId])
  @@index([driverId])
  @@index([kpiDefinitionId])
  @@index([date])
}

// 32. Notification - in-app notification for users
model Notification {
  id        String    @id @default(uuid())
  tenantId  String
  userId    String?
  title     String
  message   String
  type      String // violation type or alert type (e.g. "GPS_OFF", "cash_overdue")
  severity  String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  sourceId  String? // ID of the violation event or alert that triggered this
  metadata  Json?
  read      Boolean   @default(false)
  readAt    DateTime?
  category  String? // "IMPORTANT", "OPS_TODO", "BENEFITS", "OTHER"
  titleAr   String?
  bodyAr    String?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

// 32b. NotificationDelivery - outbound delivery audit for external channels
//      (WhatsApp, Email, SMS). Persisted by the notification queue worker so
//      failures are visible and retriable.
model NotificationDelivery {
  id             String                     @id @default(uuid())
  tenantId       String
  channel        NotificationChannel
  recipient      String
  subject        String?
  body           String
  provider       String? // twilio, sendgrid, resend, stub
  status         NotificationDeliveryStatus @default(QUEUED)
  idempotencyKey String?                    @unique
  error          String?
  attempts       Int                        @default(0)
  lastAttemptAt  DateTime?
  sentAt         DateTime?
  sourceType     String? // violation type, alert type, digest, etc.
  sourceId       String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, channel, createdAt])
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
  SMS
}

enum NotificationDeliveryStatus {
  QUEUED
  SENDING
  SENT
  FAILED
  DEAD
}

// 33. NotificationRule - maps violation types to user roles
model NotificationRule {
  id        String   @id @default(uuid())
  tenantId  String
  eventType String // ViolationEventType value or alert type
  role      UserRole
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, eventType, role])
  @@index([tenantId])
}

// 34. CourierOnlineSession - tracks real-time courier online status for monitor
model CourierOnlineSession {
  id         String    @id @default(uuid())
  tenantId   String
  driverId   String
  startTime  DateTime
  endTime    DateTime?
  isOnline   Boolean   @default(true)
  lastGpsAt  DateTime?
  lastGpsLat Decimal?  @db.Decimal(10, 7)
  lastGpsLng Decimal?  @db.Decimal(10, 7)
  area       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@index([tenantId, isOnline])
  @@index([driverId, startTime])
}

// 35. Violation - cross-platform violation with penalty/appeal workflow
model Violation {
  id                 String          @id @default(uuid())
  tenantId           String
  driverId           String?
  platform           Platform
  violationType      ViolationType
  violationStatus    ViolationStatus @default(ESTABLISHED)
  appealStatus       AppealStatus    @default(NOT_RAISED)
  firstAppealStatus  AppealStatus    @default(NOT_RAISED)
  secondAppealStatus AppealStatus    @default(NOT_RAISED)
  violationTime      DateTime
  details            String?
  metadata           Json?
  taskId             String?
  overrideReason     String?
  overriddenBy       String?
  overriddenAt       DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  driver    Driver?   @relation(fields: [driverId], references: [id])
  penalties Penalty[]
  appeals   Appeal[]

  @@index([tenantId, violationTime])
  @@index([driverId, violationType])
  @@index([tenantId, platform, violationStatus])
}

// 36. Penalty - linked to violations via implicit m2m
model Penalty {
  id            String   @id @default(uuid())
  tenantId      String
  driverId      String
  penaltyType   String // ONLINE_TRAINING, VIOLATION_RECORD, ACCOUNT_SUSPENSION, WARNING
  penaltyStatus String   @default("EFFECTIVE") // EFFECTIVE, COMPLETED, OVERTURNED
  penaltyValue  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  driver     Driver      @relation(fields: [driverId], references: [id])
  violations Violation[]

  @@index([tenantId, driverId])
  @@index([tenantId, penaltyStatus])
}

// 37. Appeal - violation appeal with review workflow
model Appeal {
  id            String       @id @default(uuid())
  tenantId      String
  violationId   String
  appealLevel   Int          @default(1) // 1 = first appeal, 2 = second appeal
  appealStatus  AppealStatus @default(PENDING)
  channel       String? // APP, PHONE, EMAIL
  reason        String?
  rejectionNote String?
  appealedAt    DateTime     @default(now())
  reviewedAt    DateTime?
  reviewedBy    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  violation Violation @relation(fields: [violationId], references: [id])

  @@unique([violationId, appealLevel])
  @@index([violationId])
  @@index([tenantId, appealStatus])
}

// 38. OrderEvent - order lifecycle events for flow timeline
model OrderEvent {
  id          String   @id @default(uuid())
  tenantId    String
  orderId     String
  action      String
  description String
  operator    String?
  operatorId  String?
  timestamp   DateTime
  metadata    Json?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, orderId])
  @@index([orderId, timestamp])
}

// 39. AiInsight - pre-computed AI-driven operational recommendations
model AiInsight {
  id          String   @id @default(uuid())
  tenantId    String
  category    String // REVENUE, WORKFORCE, FINANCIAL, COMPLIANCE, COACHING, EFFICIENCY
  subcategory String // e.g. "idle_positioning", "shift_gap", "cash_priority"
  context     String // page where this appears: "keeta/monitor", "dashboard", etc.
  severity    String   @default("INFO") // INFO, WARNING, CRITICAL, OPPORTUNITY
  title       String
  description String
  actionLabel String?
  actionHref  String?
  data        Json?
  driverId    String?
  platform    String?
  score       Float    @default(0) // priority ranking
  expiresAt   DateTime
  batchId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  driver Driver? @relation(fields: [driverId], references: [id])

  @@index([tenantId, context, expiresAt])
  @@index([tenantId, category])
  @@index([tenantId, driverId])
}

// 40. DemandHeatmap - pre-computed restaurant demand by zone/time for real-time positioning
model DemandHeatmap {
  id             String   @id @default(uuid())
  tenantId       String
  platform       String
  zone           String
  dayOfWeek      Int // 0=Sun, 6=Sat
  hourSlot       Int // 0-23
  avgOrders      Float
  topRestaurants Json // [{name, avgOrders, lat, lng}]
  confidence     Float // 0-1
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, platform, zone, dayOfWeek, hourSlot])
  @@index([tenantId, platform])
}

// ─── KEETA PARITY (F7–F14) ──────────────────────────────────────────────────

// Amendment B — configurable delivery areas per tenant
model DeliveryArea {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  nameAr    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@index([tenantId, active])
}

// F9 — 3-hour attendance slot per courier per day
model CourierAttendanceSlot {
  id         String   @id @default(uuid())
  tenantId   String
  driverId   String
  date       DateTime @db.Date
  slotStart  Int // 0, 3, 6, 9, 12, 15, 18, 21
  slotEnd    Int
  status     String // ON_SHIFT | NO_SHIFT | PARTIAL
  onShiftMin Int      @default(0)
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@unique([tenantId, driverId, date, slotStart])
  @@index([tenantId, date])
}

// Driver-app "available shifts" — open slots drivers can claim in the platform app.
// Mirrored here so admins can see / plan capacity alongside booked shifts.
model KeetaAvailableShiftSlot {
  id          String   @id @default(cuid())
  tenantId    String
  platform    Platform @default(KEETA)
  date        DateTime
  area        String
  slotStart   String // "HH:mm"
  slotEnd     String // "HH:mm"
  capacity    Int      @default(0)
  claimed     Int      @default(0)
  vehicleType String? // BIKE, CAR — optional scope
  branchId    String?
  branchName  String?
  source      String   @default("MANUAL") // MANUAL, KEETA_SYNC, TALABAT_SYNC
  externalId  String? // id from the platform app when synced
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, platform, date, area, slotStart, vehicleType])
  @@index([tenantId, platform, date])
  @@index([tenantId, platform, area])
}

// F10 — per-tenant shift compliance configuration
model ShiftComplianceConfig {
  tenantId        String   @id
  underShiftHours Float    @default(10)
  evaluateCron    String   @default("0 6 * * *")
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// F11 — Partner & bank account
model Partner {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  groupId   String
  groupName String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant                 @relation(fields: [tenantId], references: [id])
  bankAccounts    PartnerBankAccount[]
  billings        Billing[]
  incentiveRounds IncentiveTargetRound[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model PartnerBankAccount {
  id          String   @id @default(uuid())
  partnerId   String
  bankName    String
  accountName String
  tailNumber  String // last 4 of IBAN
  verified    Boolean  @default(true)
  createdAt   DateTime @default(now())

  partner Partner @relation(fields: [partnerId], references: [id])

  @@index([partnerId])
}

// F11 — Incentive engine
model IncentiveTargetRound {
  id             String   @id @default(uuid())
  tenantId       String
  partnerId      String
  period         String // "202604"
  vehicleType    String // CAR | MOTORCYCLE
  issuedAt       DateTime
  initialTarget  Int
  adjustedTarget Int?
  status         String   @default("ACTIVE") // ACTIVE | CLOSED
  operator       String   @default("Keeta OPS")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant  Tenant                   @relation(fields: [tenantId], references: [id])
  partner Partner                  @relation(fields: [partnerId], references: [id])
  goals   IncentiveGoal[]
  tiers   IncentiveTier[]
  payouts CourierIncentivePayout[]

  @@unique([tenantId, partnerId, period, vehicleType])
  @@index([tenantId, period])
}

model IncentiveGoal {
  id           String @id @default(uuid())
  roundId      String
  name         String // ORDER_COMPLETION_PCT | ON_TIME_RATE
  weight       Float
  targetValue  Float
  minThreshold Float

  round IncentiveTargetRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([roundId])
}

model IncentiveTier {
  id      String @id @default(uuid())
  roundId String
  kind    String // EXPERIENCE | VALID_DA
  level   String // A | B | C | D
  minRate Float
  maxRate Float
  payment Int

  round IncentiveTargetRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([roundId, kind])
}

model CourierIncentivePayout {
  id               String   @id @default(uuid())
  tenantId         String
  roundId          String
  driverId         String
  experienceRate   Float    @default(0)
  experienceTier   String?
  experiencePayKwd Int      @default(0)
  validDaCount     Int      @default(0)
  validDaTier      String?
  validDaPayKwd    Int      @default(0)
  totalPayKwd      Int      @default(0)
  computedAt       DateTime @default(now())

  tenant Tenant               @relation(fields: [tenantId], references: [id])
  round  IncentiveTargetRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  driver Driver               @relation(fields: [driverId], references: [id])

  @@unique([roundId, driverId])
  @@index([tenantId, driverId])
}

// F12 — Financial management
enum BillingStatus {
  PENDING_INVOICE
  AWAITING_APPROVAL
  APPROVED
  PAID
  REJECTED
}

enum TaxInvoiceStatus {
  DRAFT
  SUBMITTED
  ACCEPTED
  REJECTED
}

enum WithdrawalStatus {
  PENDING
  WITHDRAWN
  FAILED
}

model Billing {
  id            String        @id @default(uuid())
  tenantId      String
  partnerId     String
  groupId       String
  groupName     String
  billingId     String        @unique
  billType      String // MONTHLY_SETTLEMENT | ADJUSTMENT
  period        String // "202604"
  billingDate   DateTime
  invoiceAmount Decimal       @db.Decimal(18, 3)
  payableAmount Decimal       @db.Decimal(18, 3)
  status        BillingStatus @default(PENDING_INVOICE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  partner     Partner             @relation(fields: [partnerId], references: [id])
  taxInvoice  TaxInvoice?
  withdrawals PaymentWithdrawal[]

  @@index([tenantId, period])
  @@index([tenantId, status])
}

model TaxInvoice {
  id           String           @id @default(uuid())
  tenantId     String
  billingId    String           @unique
  invoiceNo    String
  issueDate    DateTime
  sellerName   String
  totalAmount  Decimal          @db.Decimal(18, 3)
  fileUrl      String?
  status       TaxInvoiceStatus @default(DRAFT)
  rejectReason String?
  submittedAt  DateTime?
  acceptedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  billing Billing @relation(fields: [billingId], references: [id])

  @@index([tenantId, status])
}

model PaymentWithdrawal {
  id              String           @id @default(uuid())
  tenantId        String
  billingId       String
  groupId         String
  groupName       String
  withdrawTime    DateTime
  tailNumber      String
  amountKwd       Decimal          @db.Decimal(18, 3)
  status          WithdrawalStatus @default(PENDING)
  operationStatus String           @default("Withdrawn")
  note            String           @default("SYSTEM AUTO WITHDRAW")
  createdAt       DateTime         @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  billing Billing @relation(fields: [billingId], references: [id])

  @@index([tenantId, withdrawTime])
}

// ─── Agent Runtime (v2) ──────────────────────────────────────────────────────
// One AgentRunLog per agent invocation. AgentToolCall rows record every tool
// the agent called during that run. PendingAgentAction is the human approval
// queue for write tools that didn't meet the auto-execute threshold.

model AgentRunLog {
  id               String    @id @default(cuid())
  tenantId         String
  agentId          String // "triage" | "reconciliation" | "narrator" | "chat"
  triggerEvent     String // e.g. "violation", "appeal_submitted", "cron:15m"
  model            String
  promptTokens     Int       @default(0)
  completionTokens Int       @default(0)
  startedAt        DateTime  @default(now())
  finishedAt       DateTime?
  status           String    @default("running") // running | completed | failed
  error            String?
  actionsProposed  Int       @default(0)
  actionsApproved  Int       @default(0)
  actionsRejected  Int       @default(0)
  feedback         Json?

  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  toolCalls     AgentToolCall[]
  pending       PendingAgentAction[]
  agentActions  AgentAction[]
  agentMemories AgentMemory[]

  @@index([tenantId, agentId, startedAt])
  @@index([tenantId, status])
}

model AgentToolCall {
  id         String   @id @default(cuid())
  runId      String
  toolName   String
  input      Json
  output     Json?
  error      String?
  durationMs Int      @default(0)
  approvedBy String? // userId of approving operator, if human-gated
  executedAt DateTime @default(now())

  run AgentRunLog @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([toolName, executedAt])
}

model PendingAgentAction {
  id             String    @id @default(cuid())
  tenantId       String
  runId          String
  agentId        String
  toolName       String
  input          Json
  recommendation String // "approve" | "reject" | "escalate"
  confidence     Float     @default(0)
  reasoning      String
  priorityScore  Float     @default(0)
  subjectType    String? // "appeal" | "violation" | "cash_record" | ...
  subjectId      String?
  resolvedAt     DateTime?
  resolution     String? // "approved" | "rejected"
  overrideReason String?
  resolvedBy     String?
  createdAt      DateTime  @default(now())

  tenant Tenant      @relation(fields: [tenantId], references: [id])
  run    AgentRunLog @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([tenantId, resolvedAt, priorityScore])
  @@index([tenantId, agentId, resolvedAt])
  @@index([subjectType, subjectId])
}

// ─── Agent Spine v2 — Phase 1 (audit ledger, memory, pinned views, snapshots, analytics) ───
// CON-audit-row-shape: AgentAction is the canonical record of every fired agent action.
// Distinct from AgentRunLog (one row per LLM invocation) and PendingAgentAction
// (one row per un-resolved write proposal). This is the row the founder sees
// when answering "what did Darb do for me last week?".

model AgentAction {
  id                          String    @id @default(cuid())
  tenantId                    String
  proposer                    String    @default("Darb")
  approverId                  String
  toolName                    String
  originalProposal            Json
  modificationsBeforeApproval Json?
  outcome                     String // "success" | "failure" | "rolled_back"
  reasoning                   String    @db.Text
  agentRunId                  String?
  modelName                   String?
  promptTokens                Int       @default(0)
  completionTokens            Int       @default(0)
  latencyMs                   Int       @default(0)
  errorMessage                String?
  subjectType                 String? // "Driver" | "Shift" | "CashRecord" | ...
  subjectId                   String?
  rolledBackAt                DateTime?
  rolledBackById              String?
  rollbackReason              String?
  createdAt                   DateTime  @default(now())

  tenant   Tenant       @relation(fields: [tenantId], references: [id])
  approver User         @relation("AgentActionApprover", fields: [approverId], references: [id])
  agentRun AgentRunLog? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, toolName, createdAt])
  @@index([tenantId, subjectType, subjectId])
  @@index([approverId])
}

// Append-only per-tenant key/value notes. Latest-by-key reads use orderBy createdAt desc.
// Source values: "agent_observation" | "user_correction" | "explicit_set".

model AgentMemory {
  id         String   @id @default(cuid())
  tenantId   String
  key        String
  value      Json
  confidence Float    @default(0.5)
  source     String?
  agentRunId String?
  createdAt  DateTime @default(now())

  tenant   Tenant       @relation(fields: [tenantId], references: [id])
  agentRun AgentRunLog? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)

  @@index([tenantId, key, createdAt(sort: Desc)])
  @@index([tenantId, createdAt])
}

// Saved generated views per user. Phase 4 (chat) consumes; Phase 1 only ships the schema.
// viewType: "table" | "chart" | "kpi_strip" | "map" | "comparison".

model PinnedView {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String
  title        String
  description  String?  @db.Text
  viewType     String
  spec         Json
  sortOrder    Int      @default(0)
  pinnedAt     DateTime @default(now())
  lastViewedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation("PinnedViewOwner", fields: [userId], references: [id])

  @@index([tenantId, userId, sortOrder])
  @@index([userId, pinnedAt])
}

// Daily snapshot of the composite score and contributing components.
// Backs the Driver File 90-day trend (Phase 3 consumer).
// Computed once per day by a worker (Wave 2 ships the writer); tools READ from this table.

model PerformanceSnapshot {
  id                String     @id @default(cuid())
  tenantId          String
  driverId          String
  snapshotDate      DateTime // truncated to UTC midnight
  compositeScore    Int
  attendanceScore   Int
  deliveryScore     Int
  financialScore    Int
  equipmentScore    Int
  platformScore     Int
  trend             ScoreTrend @default(STABLE)
  ordersCount       Int        @default(0)
  shiftsCount       Int        @default(0)
  violationsCount   Int        @default(0)
  cashOutstandingKd Decimal?   @db.Decimal(10, 3)
  breakdown         Json?
  computedAt        DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@unique([tenantId, driverId, snapshotDate])
  @@index([tenantId, snapshotDate])
  @@index([driverId, snapshotDate])
}

// Lightweight in-product analytics. The agent uses this to "see itself" (DEC-add-metric-events).
// Phase 1 ships the table + a recordMetricEvent helper; querying is Phase 11+.

model MetricEvent {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  event      String
  properties Json?
  sessionId  String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation("MetricEventActor", fields: [userId], references: [id])

  @@index([tenantId, event, createdAt])
  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
}
