generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  binaryTargets   = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions", "fullTextSearch"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

// ─── Enums ──────────────────────────────────────────────

enum Platform {
  KEETA
  TALABAT
  DELIVEROO
  AMERICANA
}

enum UserRole {
  ADMIN
  OPS_MANAGER
  SUPERVISOR
  ACCOUNTANT
  VIEWER
}

enum DriverStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TERMINATED
  LEAVE
  TERMINATION
  RESTRICTED
  RESTRICTED_PERMANENTLY
}

enum RestrictionType {
  TEMPORARY
  PERMANENT
}

enum VehicleType {
  MOTORCYCLE
  CAR
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
}

enum ShiftStatus {
  BOOKED
  IN_PROGRESS
  COMPLETED
  MISSED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  EARLY_LEAVE
  EXCUSED
  OFF
  DEDUCTION
}

enum OrderSource {
  MANUAL
  SCREENSHOT_OCR
  EXCEL_IMPORT
  AGENT_CAPTURE
  WHATSAPP
}

enum DepositMethod {
  CASH
  BANK_TRANSFER
  AL_MUZAINI
}

enum CashStatus {
  PENDING
  PARTIALLY_PAID
  SETTLED
}

enum LedgerStatus {
  OPEN
  CLOSED
}

enum InspectionStatus {
  PASS
  FAIL
}

enum MaintenanceCategory {
  SCHEDULED
  UNSCHEDULED
  EMERGENCY
}

enum MaintenanceStatus {
  REQUESTED
  APPROVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DeviceStatus {
  ACTIVE
  LOST
  DECOMMISSIONED
}

enum SimStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum DeviceCommandType {
  LOCK
  WIPE
  INSTALL_APP
  UNINSTALL_APP
  SEND_MESSAGE
  ENABLE_KIOSK
  DISABLE_KIOSK
  UPDATE_AGENT
}

enum CommandStatus {
  PENDING
  SENT
  ACKNOWLEDGED
  FAILED
}

enum ScoreTrend {
  UP
  DOWN
  STABLE
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum RecruitmentStage {
  AGENCY_REFERRAL
  CV_DOCS
  INTERVIEW
  VISA_PROCESSING
  FLIGHT_ARRANGEMENT
  ARRIVAL
  MEDICAL_EXAM
  BANK_CARD
  CIVIL_ID
  RESIDENCY
  LICENSE_TEST
  PLATFORM_TRAINING
  ROAD_SAFETY_TRAINING
  FOOD_HANDLING_TRAINING
  COMPANY_SOP_TRAINING
  COMPLETED
}

enum ComplianceEventType {
  SELFIE_FAIL
  GPS_OFF
  EQUIPMENT_MISSING
  SHIFT_NOT_BOOKED
  ORDER_CLICK_THROUGH
  LATE_CLOCK_IN
  EARLY_CLOCK_OUT
  ZONE_MISMATCH
  OUT_OF_ZONE
  CASH_THRESHOLD_EXCEEDED
}

enum InventoryItemType {
  HELMET
  TSHIRT
  PANTS
  COOLING_VEST
  SAFETY_VEST
  WATER_BOTTLE
  GLOVES
  SAFETY_KIT
  BIG_BAG
  SMALL_BAG
  CAP
  MOBILE_PHONE
  SIM_CARD
  PETROL_CARD
}

enum TicketCategory {
  VEHICLE_REPAIR
  EQUIPMENT_REQUEST
  LEAVE_REQUEST
  SALARY_ISSUE
  TRANSFER_REQUEST
  COMPLAINT
  ACCIDENT_REPORT
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SubmitterType {
